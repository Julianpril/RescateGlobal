# App
APP_NAME=RescateGlobal
NODE_ENV=development
PORT=3000

# Frontend
FRONTEND_URL=http://localhost:3000

# Backend
API_BASE_URL=http://localhost:3000/api
JWT_SECRET=your_jwt_secret_here

# Volunteer credentials JSON (example)
# VOLUNTEER_CREDENTIALS_JSON={"coord":{"password":"coord123","id":"u-coord-1","displayName":"Coordinador","role":"coordinador","location":"Tunja, Boyaca"},"vol1":{"password":"vol123","id":"u-vol-1","displayName":"Voluntario 1","role":"voluntario","location":"Tunja, Boyaca"}}
VOLUNTEER_CREDENTIALS_JSON=

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
